<Window x:Class="Volkswagen_Automobili.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Volkswagen_Automobili"
        mc:Ignorable="d" ResizeMode="NoResize" AllowsTransparency="True" WindowStyle="None" Background="#001236"
        Title="Login Page" Height="510" Width="720" WindowStartupLocation="CenterScreen">

    <Canvas>
        <Image Source="/Images/volfsburg.png" VerticalAlignment="Top" HorizontalAlignment="Left" Height="510" Width="720"/>
        <!-- Naslov -->
        <Label Content="Volkswagen Database" x:Name="titleLB" FontSize="32" FontFamily="Tahoma" HorizontalContentAlignment="Center"
               Foreground="White" Width="422" Canvas.Left="149" Canvas.Top="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Login -->
        <Label Content="User:" x:Name="loginLB"  FontSize="24" FontFamily="Tahoma" Foreground="White"  Height="52" HorizontalContentAlignment="Right"
               Canvas.Left="186" Canvas.Top="175" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="-0.04,0.55" Width="122"/>
        <TextBox x:Name="loginTB" FontSize="16" Width="230" Height="30" VerticalContentAlignment="Center"
               Canvas.Left="316" Canvas.Top="179" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <!-- Password -->
        <Label Content="Password:" x:Name="passwordLB" FontSize="24" FontFamily="Tahoma" Foreground="White" Height="43"
               Canvas.Left="186" Canvas.Top="225" HorizontalAlignment="Right" VerticalAlignment="Top" HorizontalContentAlignment="Right"/>
        <PasswordBox x:Name="passwTB" FontSize="16" Width="230" Height="30" VerticalContentAlignment="Center"
               Canvas.Left="316" Canvas.Top="229" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <!-- Bottom Bar -->
        <Border Background="Black" Width="720" Height="100"
                Canvas.Left="0" Canvas.Top="412" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0.85">
            <Grid Margin="20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="18*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- login dugme -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,20,0,0" Grid.RowSpan="2">
                    <Button Content="Log in" Width="140" Height="60" FontSize="20" FontFamily="Segoe UI" x:Name="login_button"
                            Click="loginButton_Click"  Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>

                <!-- Logo -->
                <Image Grid.Column="1" Source="/Images/vwBlueMini.png"
                       Height="70" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0" Grid.RowSpan="2"/>

                <!-- Exit -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,0,0" Grid.RowSpan="2">
                    <Button Content="Exit" Width="140" Height="60" FontSize="20" FontFamily="Segoe UI"
                            Click="exitButton_Click" x:Name="exit_button"
                            Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>

                <Image Source="/Images/GERf.png" Stretch="Uniform" Grid.Column="2" 
                    Width="123"  Margin="277,-400,0,412" HorizontalAlignment="Left" MouseDown="ger_click" />
                <Image Source="/Images/ENGf.png" Stretch="Uniform" Grid.Column="2" 
                    Width="123"  Margin="277,-377,0,389" HorizontalAlignment="Left" MouseDown="eng_click" />
                <Image Source="/Images/SRBf.png" Stretch="Uniform" Grid.Column="2" 
                    Width="123"  Margin="277,-353,0,365" HorizontalAlignment="Left" MouseDown="srb_click" />

            </Grid>
        </Border>
        <Label Content="Das Auto." Canvas.Left="329" Canvas.Top="486" Foreground="White" FontSize="12" VerticalAlignment="Top" HorizontalAlignment="Center"/>

    </Canvas>
</Window>
