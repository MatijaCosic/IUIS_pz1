<Window x:Class="Volkswagen_Automobili.Pages.AddVehicle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Volkswagen_Automobili.Pages"
        mc:Ignorable="d"
        Title="AddVehicle" ResizeMode="NoResize" AllowsTransparency="True" WindowStyle="None" Background="#001236"
        Height="510" Width="720" WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid>
        <Canvas>
            <Image Source="C:\Users\Matija\Desktop\FTN\6_Semestar\IUIS\IUIS_projekat_PR131_2022\VWslike\volfsburg.png" VerticalAlignment="Top" HorizontalAlignment="Left" Height="510" Width="720"/>

            <!-- Bottom Bar -->
            <Border Background="Black" Width="720" Height="100"
            Canvas.Left="0" Canvas.Top="412" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0.85">
                <Grid Margin="20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="18*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- dugmad levo -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,20,0,0" Grid.RowSpan="2">
                        <!-- abort dugme -->
                        <Button Content="Cancel" Width="123" Height="60" FontSize="20" FontFamily="Segoe UI" x:Name="cancel_button"
                        Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Cancel_button_Click"/>
                    </StackPanel>

                    <!-- Logo -->
                    <Image Grid.Column="1" Source="C:\Users\Matija\Desktop\FTN\6_Semestar\IUIS\IUIS_projekat_PR131_2022\VWslike\vwBlueMini.png" 
                        Height="70" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0" Grid.RowSpan="2"/>

                    <!-- Dugmad Desno -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,0,0" Grid.RowSpan="2">
                        <!-- Delete Item -->
                        <Button Content="ADD" Width="120" Height="60" FontSize="20" FontFamily="Segoe UI" Margin="10,0"
                        Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" x:Name="delete_button" Click="ADDfinalize_button_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Label Content="Das Auto." Canvas.Left="329" Canvas.Top="486" Foreground="White" FontSize="12" VerticalAlignment="Top" HorizontalAlignment="Center"/>
        </Canvas>

        <Label Content="Model name:" Canvas.Left="106" Canvas.Top="107" FontSize="20" FontFamily="Arial Black" Margin="35,42,501,433"
               HorizontalContentAlignment="Right" Foreground="White"/>
        <Label Content="Image path:" Canvas.Left="106" Canvas.Top="107" FontSize="20" FontFamily="Arial Black" Margin="75,95,501,381" 
                HorizontalContentAlignment="Right" Foreground="White"/>
        <Label Content="Price:" Canvas.Left="106" Canvas.Top="107" FontSize="20" FontFamily="Arial Black" Margin="147,147,501,328"
                HorizontalContentAlignment="Right" Foreground="White"/>

        <TextBox  FontSize="16" Width="309" Height="35" VerticalContentAlignment="Center" x:Name="textBoxName"
       Canvas.Left="316" Canvas.Top="179" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="224,42,0,0" TextChanged="textBoxName_TextChanged"/>
        <Label x:Name="errorName" Content="Model Name cannot be empty!" Foreground="Red" FontSize="12" Margin="358,44,187,436" Visibility="Collapsed" />
        <TextBox FontSize="16" Width="309" Height="34" VerticalContentAlignment="Center" x:Name="textBoxSlika" Text="Double click..." IsReadOnly="True" Foreground="Gray"
       Canvas.Left="316" Canvas.Top="179" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="224,95,0,0" MouseDoubleClick="imagePathTextBox_MouseDoubleClick"/>
        <Label x:Name="errorSlika" Content="Image path must be provided!" Foreground="Red" FontSize="12" Margin="360,100,187,381" Visibility="Collapsed"/>
        <TextBox FontSize="16" Width="309" Height="35" VerticalContentAlignment="Center" x:Name="textBoxCena" 
       Canvas.Left="316" Canvas.Top="179" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="224,147,0,0" TextChanged="textBoxCena_TextChanged"/>
        <Label x:Name="errorCena" Content="Price must be provided!" Foreground="Red" FontSize="12" Margin="378,151,187,328" Visibility="Collapsed"/>
        <RichTextBox Margin="10,246,10,105" x:Name="richTextBox" FontSize="14" SelectionChanged="richTextBox_TextChanged" >
            <FlowDocument>
                <Paragraph>
                    <Run Text=""/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
        <Label x:Name="errorRTB" Content="Description cannot be empty!" Foreground="Red" FontSize="14" Margin="434,372,91,107"  Visibility="Collapsed"/>
        <ToolBar DockPanel.Dock="Top" Margin="4,216,9,264">
            <ToggleButton x:Name="btnBold" Content="B" FontWeight="Bold" Checked="btnBold_Checked" Width="23" />
            <ToggleButton x:Name="btnItalic" Content="I" FontStyle="Italic" Width="21" Click="btnItalic_Click"/>
            <ToggleButton x:Name="btnUnderline" Content="U" Width="26" Checked="btnUnderline_Checked" />

            <!-- Font family -->
            <ComboBox x:Name="cmbFontFamily" Width="150" SelectionChanged="cmbFontFamily_SelectionChanged" />

            <!-- Font size -->
            <ComboBox x:Name="cmbFontSize" Width="105" SelectionChanged="cmbFontSize_SelectionChanged" >
                <ComboBoxItem Content="10"/>
                <ComboBoxItem Content="12"/>
                <ComboBoxItem Content="14"/>
                <ComboBoxItem Content="16"/>
                <ComboBoxItem Content="18"/>
                <ComboBoxItem Content="20"/>
                <ComboBoxItem Content="24"/>
            </ComboBox>

            <!-- Text color -->
            <Button Content="Boja" Width="88" HorizontalAlignment="Left" Click="colorButton_Click" />
        </ToolBar>



        <StatusBar Margin="634,372,12,107" RenderTransformOrigin="0.516,0.151" >
            <TextBlock x:Name="wordCountText" Text="words: 0"/>
        </StatusBar>
        <Image x:Name="previewImage"  HorizontalAlignment="Left" Height="103" Margin="538,42,0,0" VerticalAlignment="Top" Width="164" RenderTransformOrigin="0.27,-0.295"/>

    </Grid>
</Window>
